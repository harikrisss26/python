from collections import OrderedDict
n = int(input())
item_dict = OrderedDict()
for _ in range(n):
    data = input().rsplit(' ', 1)
    item_name = data[0]
    net_price = int(data[1])
    if item_name in item_dict:
        item_dict[item_name] += net_price
    else:
        item_dict[item_name] = net_price
for item, price in item_dict.items():
    print(f"{item} {price}")
