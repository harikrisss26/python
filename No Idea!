def calculate_happiness():

    n_m = list(map(int, input().split()))
    arr = list(map(int, input().split()))
    A = set(map(int, input().split()))
    B = set(map(int, input().split()))

    happiness = 0
    for num in arr:
        if num in A:
            happiness += 1
        elif num in B:     
            happiness -= 1        
    print(happiness)
if __name__ == "__main__":
    calculate_happiness()
